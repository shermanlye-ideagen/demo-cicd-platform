{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ideagen.com/cicd/tenant-schema.json",
  "title": "Tenant Registry",
  "description": "Schema for product tenant registry files (tenants/registry.yaml)",
  "type": "object",
  "required": ["apiVersion", "kind", "product", "tenants"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "v1"
    },
    "kind": {
      "type": "string",
      "const": "TenantRegistry"
    },
    "product": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,62}[a-z0-9]$",
      "description": "Product name, must match entry in config/products.json"
    },
    "tenants": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tenant"
      },
      "minItems": 0,
      "maxItems": 500
    }
  },
  "$defs": {
    "tenant": {
      "type": "object",
      "required": ["name", "tier", "region", "status"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,40}$",
          "description": "Tenant identifier (lowercase, hyphens, 3-41 chars)"
        },
        "tier": {
          "type": "string",
          "enum": ["bronze", "silver", "gold"],
          "description": "Infrastructure tier — references config/tenants/tiers/{tier}.yaml"
        },
        "region": {
          "type": "string",
          "enum": [
            "us-east-1", "us-east-2", "us-west-1", "us-west-2",
            "eu-west-1", "eu-west-2", "eu-central-1",
            "ap-southeast-1", "ap-southeast-2", "ap-northeast-1"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["active", "suspended", "decommissioning", "decommissioned"],
          "description": "Tenant lifecycle status"
        },
        "config": {
          "$ref": "#/$defs/tenant_config"
        },
        "compliance": {
          "$ref": "#/$defs/compliance"
        },
        "overrides": {
          "type": "boolean",
          "default": false,
          "description": "Whether this tenant has an overrides/{name}.yaml file"
        },
        "decommission_after": {
          "type": "string",
          "format": "date",
          "description": "Date after which decommissioning infra can be destroyed (ISO 8601)"
        },
        "created_at": {
          "type": "string",
          "format": "date",
          "description": "Date tenant was first provisioned"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "decommissioning" } }
          },
          "then": {
            "required": ["decommission_after"]
          }
        }
      ]
    },
    "tenant_config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scaling": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "minReplicas": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 1
            },
            "maxReplicas": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 5
            }
          }
        },
        "resources": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu_request": { "type": "string", "pattern": "^[0-9]+m?$" },
            "cpu_limit": { "type": "string", "pattern": "^[0-9]+m?$" },
            "memory_request": { "type": "string", "pattern": "^[0-9]+(Mi|Gi)$" },
            "memory_limit": { "type": "string", "pattern": "^[0-9]+(Mi|Gi)$" }
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Extra environment variables injected into tenant pods"
        }
      }
    },
    "compliance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dataResidency": {
          "type": "string",
          "enum": ["eu", "us", "ap", "any"],
          "description": "Region constraint for data storage"
        },
        "encryption": {
          "type": "string",
          "enum": ["aws-managed", "cmk"],
          "default": "aws-managed",
          "description": "Encryption key type — cmk uses customer-managed KMS key"
        },
        "backupRetentionDays": {
          "type": "integer",
          "minimum": 7,
          "maximum": 365,
          "default": 30
        }
      }
    }
  }
}
